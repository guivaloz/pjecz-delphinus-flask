{% extends 'layouts/app.jinja2' %}
{% import 'macros/list.jinja2' as list %}
{% import 'macros/topbar.jinja2' as topbar %}

{% block title %}{{ titulo }}{% endblock %}

{% block topbar_actions %}
    {% call topbar.page_buttons(titulo) %}
        {% if current_user.can_view('UDP TIPOS CONDICIONES') %}
            {{ topbar.button('Tipos Condiciones', url_for('udp_tipos_condiciones.list_active'), 'mdi mdi-tag-multiple') }}
        {% endif %}
        {% if current_user.can_view('UDP TIPOS TRAMITES') %}
            {{ topbar.button('Tipos Trámites', url_for('udp_tipos_tramites.list_active'), 'mdi mdi-file-document') }}
        {% endif %}
        {% if current_user.can_view('UDP TIPOS VISITAS') %}
            {{ topbar.button('Tipos Visitas', url_for('udp_tipos_visitas.list_active'), 'mdi mdi-calendar-check') }}
        {% endif %}
        {% if current_user.can_admin('UDP SEXOS') %}
            {% if estatus == 'A' %}{{ topbar.button_list_inactive('Inactivos', url_for('udp_sexos.list_inactive')) }}{% endif %}
            {% if estatus == 'B' %}{{ topbar.button_list_active('Activos', url_for('udp_sexos.list_active')) }}{% endif %}
        {% endif %}
        {% if current_user.can_insert('UDP SEXOS') %}
            {{ topbar.button_new('Nuevo', url_for('udp_sexos.new')) }}
        {% endif %}
    {% endcall %}
{% endblock %}

{% block content %}
    {% call list.card() %}
        <!-- Filtros udp_sexos -->
        <div class="row">
            <div class="col">
                <form class="row g-1 mb-3" id="filtradorForm" onsubmit="filtrosUdpSexos.buscar(); return false;">
                    <div class="col-6">
                        <div class="form-floating">
                            <input id="filtroUdpSexoNombre" type="text" class="form-control" aria-label="Nombre" style="text-transform: uppercase;">
                            <label for="filtroUdpSexoNombre">Nombre</label>
                        </div>
                    </div>
                    <div class="col-6 text-end">
                        <button title="Buscar" class="btn btn-primary btn-lg" onclick="filtrosUdpSexos.buscar(); return false;" id="button-buscar"><span class="mdi mdi-magnify"></span></button>
                        <button title="Limpiar" class="btn btn-warning btn-lg" type="reset" onclick="filtrosUdpSexos.limpiar();" id="button-limpiar"><span class="mdi mdi-broom"></span></button>
                    </div>
                </form>
            </div>
        </div>
        <!-- Datatable udp_sexos -->
        <table id="udp_sexos_datatable" class="table {% if estatus == 'B'%}table-dark{% endif %} display nowrap" style="width:100%">
            <thead>
                <tr>
                    <th>Nombre</th>
                </tr>
            </thead>
        </table>
    {% endcall %}
{% endblock %}

{% block custom_javascript %}
    <script src="/static/js/datatables-constructor.js"></script>
    <script src="/static/js/datatables-filtros.js"></script>
    <script>
        // DataTable udp_sexos
        const constructorDataTable = new ConfigDataTable( '{{ csrf_token() }}' );
        let configDTUdpSexos = constructorDataTable.config();
        configDTUdpSexos['ajax']['url'] = "{{ url_for('udp_sexos.datatable_json') }}";
        configDTUdpSexos['ajax']['data'] = {{ filtros }};
        configDTUdpSexos['columns'] = [
            { data: 'detalle' }
        ];
        configDTUdpSexos['columnDefs'] = [
            {
                targets: 0,
                data: null,
                render: function(data, type, row, meta) {
                    return '<a href="' + data.url + '">' + data.nombre + '</a>';
                }
            }
        ];
        // Filtros udp_sexos
        const filtrosUdpSexos = new FiltrosDataTable('#udp_sexos_datatable', configDTUdpSexos);
        filtrosUdpSexos.agregarInput('filtroUdpSexoNombre', 'nombre');
        filtrosUdpSexos.precargar();
    </script>
{% endblock %}
