{% extends 'layouts/app.jinja2' %}
{% import 'macros/detail.jinja2' as detail %}
{% import 'macros/modals.jinja2' as modals %}
{% import 'macros/topbar.jinja2' as topbar %}

{% block title %}Visita {{ udp_persona_visita.id }}{% endblock %}

{% block topbar_actions %}
    {% call topbar.page_buttons('Visita ' + udp_persona_visita.id | string) %}
        {{ topbar.button_previous('Persona', url_for('udp_personas.detail', udp_persona_id=udp_persona_visita.udp_persona_id)) }}
        {% if current_user.can_edit('UDP PERSONAS VISITAS') %}
            {{ topbar.button_edit('Editar', url_for('udp_personas_visitas.edit', udp_persona_visita_id=udp_persona_visita.id)) }}
        {% endif %}
        {% if current_user.can_admin('UDP PERSONAS VISITAS') %}
            {% if udp_persona_visita.estatus == 'A' %}{{ topbar.button_delete('Eliminar', url_for('udp_personas_visitas.delete', udp_persona_visita_id=udp_persona_visita.id)) }}{% endif %}
            {% if udp_persona_visita.estatus == 'B' %}{{ topbar.button_recover('Recuperar', url_for('udp_personas_visitas.recover', udp_persona_visita_id=udp_persona_visita.id)) }}{% endif %}
        {% endif %}
    {% endcall %}
{% endblock %}

{% block content %}
    {% call detail.card(estatus=udp_persona_visita.estatus) %}
        <div class="row">
            {{ detail.label_value('Persona', udp_persona_visita.udp_persona.nombre_completo, url_for('udp_personas.detail', udp_persona_id=udp_persona_visita.udp_persona_id)) }}
            {{ detail.label_value('Tipo de Visita', udp_persona_visita.udp_tipo_tramite.nombre) }}
            {{ detail.label_value('Usuario', udp_persona_visita.usuario.email) }}
            {{ detail.label_value('Observaciones', udp_persona_visita.observaciones) }}
        </div>
    {% endcall %}
{% endblock %}

{% block custom_javascript %}
    {% if current_user.can_admin('UDP PERSONAS VISITAS') %}
        {% if udp_persona_visita.estatus == 'A' %}{{ modals.custom_javascript_delete('Eliminar', '¿Eliminar esta atención?') }}{% endif %}
        {% if udp_persona_visita.estatus == 'B' %}{{ modals.custom_javascript_recover('Recuperar', '¿Recuperar esta atención?') }}{% endif %}
    {% endif %}
{% endblock %}
