{% extends 'layouts/app.jinja2' %}
{% import 'macros/detail.jinja2' as detail %}
{% import 'macros/modals.jinja2' as modals %}
{% import 'macros/topbar.jinja2' as topbar %}

{% block title %}UDP Tipo Visita {{ udp_tipo_visita.nombre }}{% endblock %}

{% block topbar_actions %}
    {% call topbar.page_buttons('UDP Tipo Visita ' + udp_tipo_visita.nombre) %}
        {{ topbar.button_previous('UDP Tipos Visitas', url_for('udp_tipos_visitas.list_active')) }}
        {% if current_user.can_edit('UDP TIPOS VISITAS') %}
            {{ topbar.button_edit('Editar', url_for('udp_tipos_visitas.edit', udp_tipo_visita_id=udp_tipo_visita.id)) }}
        {% endif %}
        {% if current_user.can_admin('UDP TIPOS VISITAS') %}
            {% if udp_tipo_visita.estatus == 'A' %}{{ topbar.button_delete('Eliminar', url_for('udp_tipos_visitas.delete', udp_tipo_visita_id=udp_tipo_visita.id)) }}{% endif %}
            {% if udp_tipo_visita.estatus == 'B' %}{{ topbar.button_recover('Recuperar', url_for('udp_tipos_visitas.recover', udp_tipo_visita_id=udp_tipo_visita.id)) }}{% endif %}
        {% endif %}
    {% endcall %}
{% endblock %}

{% block content %}
    {% call detail.card(estatus=udp_tipo_visita.estatus) %}
        {{ detail.label_value_big('Nombre', udp_tipo_visita.nombre) }}
    {% endcall %}
{% endblock %}

{% block custom_javascript %}
    {% if current_user.can_admin('UDP TIPOS VISITAS') %}
        {% if udp_tipo_visita.estatus == 'A' %}{{ modals.custom_javascript_delete('Eliminar', '¿Eliminar a ' + udp_tipo_visita.nombre + '?') }}{% endif %}
        {% if udp_tipo_visita.estatus == 'B' %}{{ modals.custom_javascript_recover('Recuperar', '¿Recuperar a ' + udp_tipo_visita.nombre + '?') }}{% endif %}
    {% endif %}
{% endblock %}
