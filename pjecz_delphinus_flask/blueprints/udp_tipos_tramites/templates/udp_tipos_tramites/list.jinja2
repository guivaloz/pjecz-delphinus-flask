{% extends 'layouts/app.jinja2' %}
{% import 'macros/list.jinja2' as list %}
{% import 'macros/topbar.jinja2' as topbar %}

{% block title %}{{ titulo }}{% endblock %}

{% block topbar_actions %}
    {% call topbar.page_buttons(titulo) %}
        {% if current_user.can_admin('UDP TIPOS TRAMITES') %}
            {% if estatus == 'A' %}{{ topbar.button_list_inactive('Inactivos', url_for('udp_tipos_tramites.list_inactive')) }}{% endif %}
            {% if estatus == 'B' %}{{ topbar.button_list_active('Activos', url_for('udp_tipos_tramites.list_active')) }}{% endif %}
        {% endif %}
        {% if current_user.can_insert('UDP TIPOS TRAMITES') %}
            {{ topbar.button_new('Nuevo', url_for('udp_tipos_tramites.new')) }}
        {% endif %}
    {% endcall %}
{% endblock %}

{% block content %}
    {% call list.card() %}
        <!-- Filtros udp_tipos_tramites -->
        <div class="row">
            <div class="col">
                <form class="row g-1 mb-3" id="filtradorForm" onsubmit="filtrosUdpTiposTramites.buscar(); return false;">
                    <div class="col-6">
                        <div class="form-floating">
                            <input id="filtroUdpTipoTramiteNombre" type="text" class="form-control" aria-label="Nombre" style="text-transform: uppercase;">
                            <label for="filtroUdpTipoTramiteNombre">Nombre</label>
                        </div>
                    </div>
                    <div class="col-6 text-end">
                        <button title="Buscar" class="btn btn-primary btn-lg" onclick="filtrosUdpTiposTramites.buscar(); return false;" id="button-buscar"><span class="mdi mdi-magnify"></span></button>
                        <button title="Limpiar" class="btn btn-warning btn-lg" type="reset" onclick="filtrosUdpTiposTramites.limpiar();" id="button-limpiar"><span class="mdi mdi-broom"></span></button>
                    </div>
                </form>
            </div>
        </div>
        <!-- Datatable udp_tipos_tramites -->
        <table id="udp_tipos_tramites_datatable" class="table {% if estatus == 'B'%}table-dark{% endif %} display nowrap" style="width:100%">
            <thead>
                <tr>
                    <th>Nombre</th>
                </tr>
            </thead>
        </table>
    {% endcall %}
{% endblock %}

{% block custom_javascript %}
    <script src="/static/js/datatables-constructor.js"></script>
    <script src="/static/js/datatables-filtros.js"></script>
    <script>
        // DataTable udp_tipos_tramites
        const constructorDataTable = new ConfigDataTable( '{{ csrf_token() }}' );
        let configDTUdpTiposTramites = constructorDataTable.config();
        configDTUdpTiposTramites['ajax']['url'] = "{{ url_for('udp_tipos_tramites.datatable_json') }}";
        configDTUdpTiposTramites['ajax']['data'] = {{ filtros }};
        configDTUdpTiposTramites['columns'] = [
            { data: 'detalle' }
        ];
        configDTUdpTiposTramites['columnDefs'] = [
            {
                targets: 0,
                data: null,
                render: function(data, type, row, meta) {
                    return '<a href="' + data.url + '">' + data.nombre + '</a>';
                }
            }
        ];
        // Filtros udp_tipos_tramites
        const filtrosUdpTiposTramites = new FiltrosDataTable('#udp_tipos_tramites_datatable', configDTUdpTiposTramites);
        filtrosUdpTiposTramites.agregarInput('filtroUdpTipoTramiteNombre', 'nombre');
        filtrosUdpTiposTramites.precargar();
    </script>
{% endblock %}
