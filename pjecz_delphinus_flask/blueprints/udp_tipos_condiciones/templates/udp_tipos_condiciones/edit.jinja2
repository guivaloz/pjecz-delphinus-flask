{% extends 'layouts/app.jinja2' %}
{% import 'macros/form.jinja2' as f with context %}
{% import 'macros/topbar.jinja2' as topbar %}

{% block title %}Editar UDP Tipo Condicion {{ udp_tipo_condicion.nombre }}{% endblock %}

{% block topbar_actions %}
    {{ topbar.page('Editar UDP Tipo Condicion ' + udp_tipo_condicion.nombre) }}
{% endblock %}

{% block content %}
    {% call f.card() %}
        {% set form_kwargs = {'udp_tipo_condicion_id': udp_tipo_condicion.id} %}
        {% call f.form_tag('udp_tipos_condiciones.edit', fid='udp_tipo_condicion_form', **form_kwargs) %}
            {% call f.form_group(form.nombre) %}{% endcall %}
            {% call f.form_group(form.guardar) %}{% endcall %}
        {% endcall %}
    {% endcall %}
{% endblock %}
