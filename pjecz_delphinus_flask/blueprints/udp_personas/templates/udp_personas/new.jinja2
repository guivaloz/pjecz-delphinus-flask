{% extends 'layouts/app.jinja2' %}
{% import 'macros/form.jinja2' as f with context %}
{% import 'macros/topbar.jinja2' as topbar %}

{% block title %}Nueva UDP Persona{% endblock %}

{% block topbar_actions %}
    {{ topbar.page('Nueva UDP Persona') }}
{% endblock %}

{% block content %}
    {% call f.card() %}
        {% call f.form_tag('udp_personas.new', fid='udp_persona_form') %}
            <div class="row">
                <div class="col-md-6">
                    {% call f.form_group(form.nombres) %}{% endcall %}
                    {% call f.form_group(form.apellido_primero) %}{% endcall %}
                    {% call f.form_group(form.apellido_segundo) %}{% endcall %}
                    {% call f.form_group(form.curp) %}{% endcall %}
                </div>
                <div class="col-md-6">
                    {% call f.form_group(form.udp_sexo) %}{% endcall %}
                    {% call f.form_group(form.udp_tipo_condicion) %}{% endcall %}
                    {% call f.form_group(form.nacimiento_fecha) %}{% endcall %}
                    {% call f.form_group(form.observaciones) %}{% endcall %}
                </div>
            </div>
            {% call f.form_group(form.guardar) %}{% endcall %}
        {% endcall %}
    {% endcall %}
{% endblock %}

{% block custom_javascript %}
    <script>
        const udpSexoSelect = document.getElementById('udp_sexo');
        const udpTipoCondicionSelect = document.getElementById('udp_tipo_condicion');
        // Cargar las opciones del select udp_sexo
        fetch("{{ url_for('udp_sexos.select_json') }}")
            .then(response => response.json())
            .then(data => {
                data.results.forEach(item => {
                    const option = document.createElement('option');
                    option.value = item.id;
                    option.text = item.text;
                    udpSexoSelect.appendChild(option);
                });
            });
        // Cargar las opciones del select udp_tipo_condicion
        fetch("{{ url_for('udp_tipos_condiciones.select_json') }}")
            .then(response => response.json())
            .then(data => {
                data.results.forEach(item => {
                    const option = document.createElement('option');
                    option.value = item.id;
                    option.text = item.text;
                    udpTipoCondicionSelect.appendChild(option);
                });
            });
    </script>
{% endblock %}
